# Core runtime
SIM_ENV=dev
SIM_HOST=0.0.0.0
SIM_PORT=8079

# Local storage and templates
SIM_DB_PATH=./data/simulator.db
SIM_TEMPLATES_DIR=./src/helpdesk_sim/templates

# Background worker timing
SIM_POLL_INTERVAL_SECONDS=30
SIM_SCHEDULER_INTERVAL_SECONDS=30

# Zammad connection
SIM_ZAMMAD_URL=http://zammad.local
SIM_ZAMMAD_TOKEN=replace_me
SIM_ZAMMAD_VERIFY_TLS=true

# Zammad groups used when tickets are created
SIM_ZAMMAD_GROUP_TIER1=Service Desk
SIM_ZAMMAD_GROUP_TIER2=Tier 2
SIM_ZAMMAD_GROUP_SYSADMIN=Systems

# Optional fallback customer if persona lookup/create is blocked by API permissions
SIM_ZAMMAD_CUSTOMER_FALLBACK_EMAIL=

# Local testing
SIM_USE_DRY_RUN=true

# Response engine
# Use rule_based for v1-style behavior.
# Use ollama for v2 optional LLM behavior.
SIM_RESPONSE_ENGINE=rule_based

# Optional v2 Ollama settings
# Point this at your Windows PC or other Ollama host when using SIM_RESPONSE_ENGINE=ollama.
SIM_OLLAMA_URL=http://100.64.0.20:11434
SIM_OLLAMA_MODEL=llama3.1:8b

# If true, any Ollama error or weak response falls back to v1 rule-based replies.
SIM_OLLAMA_FALLBACK_TO_RULE_BASED=true

# If true, v2 can rewrite the opening ticket wording with the LLM while keeping the same hidden truth.
SIM_OLLAMA_REWRITE_OPENING_TICKETS=true

# Optional engine-control integration (recommended for shared wake/readiness control)
# When configured, runtime wake/status calls use this service first.
SIM_ENGINE_CONTROL_URL=
SIM_ENGINE_CONTROL_API_KEY=

# If true, LLM-backed operations call /v1/engine/ensure-ready before Ollama generation.
SIM_ENGINE_AUTO_WAKE=true
SIM_ENGINE_AUTO_WAKE_TIMEOUT_SECONDS=90

# Optional legacy Wake-on-LAN fallback settings for the LLM host
# These are only primary when SIM_ENGINE_CONTROL_URL / SIM_ENGINE_CONTROL_API_KEY are not set.
# Set SIM_LLM_HOST_WOL_ENABLED=true only after Wake-on-LAN is confirmed working on the target PC.
SIM_LLM_HOST_LABEL=LLM PC
SIM_LLM_HOST_WOL_ENABLED=false

# MAC address of the Windows PC to wake. Example: AA:BB:CC:DD:EE:FF
SIM_LLM_HOST_MAC=

# Broadcast target and UDP port for the Wake-on-LAN magic packet.
SIM_LLM_HOST_WOL_BROADCAST_IP=255.255.255.255
SIM_LLM_HOST_WOL_PORT=9

# Optional v2 Knowledge Base proposal workflow
# Disabled by default. This adds a manual review queue for KB proposals and can publish to an external KB provider.
SIM_KB_ENABLED=false
SIM_KB_PROVIDER=zammad
SIM_KB_REVIEW_REQUIRED=true
SIM_KB_MIN_SCORE=60
SIM_KB_SYNC_ON_START=true
SIM_KB_SYNC_INTERVAL_SECONDS=900

# Zammad KB target settings (required when SIM_KB_ENABLED=true and SIM_KB_PROVIDER=zammad)
SIM_KB_ZAMMAD_KB_ID=0
SIM_KB_ZAMMAD_LOCALE_ID=0
SIM_KB_ZAMMAD_DEFAULT_CATEGORY_ID=0
SIM_KB_ZAMMAD_PUBLISH_MODE=internal

# Optional hidden God Mode training route (`/god`)
# Disabled by default to keep standard practice mode unchanged.
SIM_GOD_MODE_ENABLED=false

# Optional access key gate for `/god` and `/v1/god/*`.
# When set, you must open `/god?k=<key>` and API requests need `X-God-Key`.
SIM_GOD_MODE_ACCESS_KEY=

# If true, trainee submits an attempt first and then receives compare/ideal guidance.
SIM_GOD_MODE_DEFAULT_ATTEMPT_FIRST=true

# Truth reveal mode for guided training (`guided` recommended).
SIM_GOD_MODE_REVEAL_MODE=guided

# Keep guided-training reports separate from normal practice reports.
SIM_GOD_MODE_SEPARATE_REPORTS=true
